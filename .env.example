# OJTracker Environment Configuration
# Copy this file to .env.local and fill in your actual values

# ─── Supabase Configuration ────────────────────────────────────────────
# Get these values from your Supabase project dashboard
# See: https://app.supabase.com/ → Project Settings → API

# Your Supabase project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anonymous public API key (safe to expose)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Server Configuration ──────────────────────────────────────────────

# Backend API URL (for local development)
VITE_API_BASE_URL=http://localhost:3001

# Server port when running `npm run server`
SERVER_PORT=3001

# ─── Feature Flags ────────────────────────────────────────────────────

# Enable debug logging
VITE_DEBUG_MODE=false

# Enable offline mode (uses fallback data)
VITE_ENABLE_OFFLINE_MODE=false

# ─── Application Configuration ─────────────────────────────────────────

# Default target hours for new profiles
VITE_DEFAULT_TARGET_HOURS=500

# Locale setting
VITE_LOCALE=en-PH

# ─── Development Settings ─────────────────────────────────────────────

# Enable hot module replacement in development
VITE_HMR=true

# Note: 
# - Environment variables must be prefixed with VITE_ to be exposed to frontend
# - Never commit .env files with real credentials
# - Use .env.local for sensitive local development values
# - Use .env.production for production values
