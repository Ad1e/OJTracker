// ─────────────────────────────────────────────────────────────────────────────
// prisma/schema.prisma
//
// OJTracker — Prisma Schema
// Database: Supabase (PostgreSQL 15)
//
// Cascade policy summary:
//   User   → Student       : CASCADE  (account deleted = profile deleted)
//   Company → Student      : RESTRICT (company cannot be deleted while students are enrolled)
//   Student → AttendanceLog: CASCADE  (student deleted = all attendance records deleted)
//
// To apply: npx prisma migrate dev --name init
// To reset: npx prisma migrate reset
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Standard pooled connection (used by the app at runtime via Supabase pgBouncer)
  url       = env("DATABASE_URL")
  // Direct non-pooled connection (required by Prisma Migrate and introspection)
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

/// Attendance status options for a single day's log entry.
/// LATE    : student arrived but logged fewer hours than the scheduled shift.
/// HALF_DAY: student was present for approximately half the standard shift.
enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
}

// ─── Models ──────────────────────────────────────────────────────────────────

/// App-level user record.
/// Mirrors a Supabase Auth user (auth.users) via `authId`.
/// All RLS policies should use `auth.uid() = authId` to scope data.
model User {
  id        String   @id @default(cuid())
  /// Supabase Auth UUID — foreign key into auth.users (managed by Supabase, not Prisma).
  authId    String   @unique @map("auth_id")
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // ── Relations ──────────────────────────────────────────────────────────────
  /// One-to-one: each authenticated user has at most one student profile.
  student   Student?

  @@index([authId])
  @@map("users")
}

/// An OJT host company / deployment site.
/// A company can host many students; a student belongs to exactly one company.
model Company {
  id              String   @id @default(cuid())
  name            String
  /// Full mailing or physical address of the company.
  address         String
  supervisorName  String   @map("supervisor_name")
  /// Used to send completion notifications; validated at the application layer.
  supervisorEmail String   @map("supervisor_email")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // ── Relations ──────────────────────────────────────────────────────────────
  /// RESTRICT: a company record cannot be deleted while students are enrolled.
  /// This is intentional — deleting a company is an admin action that requires
  /// first reassigning or graduating all enrolled students.
  students        Student[]

  @@map("companies")
}

/// A student/trainee enrolled in On-the-Job Training.
/// One-to-one with User (the authenticated account that owns this profile).
model Student {
  id            String   @id @default(cuid())
  /// School-assigned student number (e.g. "2021-00123"). Must be globally unique.
  studentId     String   @unique @map("student_id")
  name          String
  /// Total OJT hours the student must complete (e.g. 500.00).
  /// Stored as Decimal to avoid IEEE-754 float rounding on cumulative sums.
  requiredHours Decimal  @db.Decimal(6, 2) @map("required_hours")
  /// The calendar date the student officially started OJT (date only, no time).
  enrolledAt    DateTime @db.Date @map("enrolled_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // ── Foreign keys ───────────────────────────────────────────────────────────
  userId    String @unique @map("user_id")
  companyId String @map("company_id")

  // ── Relations ──────────────────────────────────────────────────────────────
  /// CASCADE: deleting the auth account removes the student profile.
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// RESTRICT: student cannot be deleted while the company record exists.
  /// The company must be reassigned or the student graduated first.
  company        Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  /// CASCADE: all attendance logs are deleted when the student is deleted.
  attendanceLogs AttendanceLog[]

  @@index([companyId])
  @@map("students")
}

/// A single day's attendance record for a student.
/// One record per student per calendar day (enforced by @@unique).
model AttendanceLog {
  id   String @id @default(cuid())

  /// Calendar date of attendance (date component only — no time zone shift risk).
  date DateTime @db.Date

  /// Clock-in time. Nullable: ABSENT entries have no timeIn or timeOut.
  timeIn  DateTime? @db.Time(0) @map("time_in")
  /// Clock-out time. Nullable: ABSENT entries have no timeIn or timeOut.
  timeOut DateTime? @db.Time(0) @map("time_out")

  /// Net hours rendered after deductions (e.g. lunch break).
  /// Stored as Decimal(4,2) — supports values like 0.00 to 99.99 hours.
  /// Must be computed and persisted by the application layer before saving;
  /// Prisma does not support computed columns.
  /// Default 0: ABSENT rows record zero hours.
  hoursRendered Decimal          @default(0) @db.Decimal(4, 2) @map("hours_rendered")

  status AttendanceStatus
  /// Free-form notes (e.g. "Arrived 30 minutes late due to transport strike").
  /// Optional: most logs will not need this field.
  notes  String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // ── Foreign keys ───────────────────────────────────────────────────────────
  studentId String @map("student_id")

  // ── Relations ──────────────────────────────────────────────────────────────
  /// CASCADE: attendance logs are removed when the student is deleted.
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  // ── Constraints ────────────────────────────────────────────────────────────
  /// Prevents duplicate entries: one log per student per calendar day.
  @@unique([studentId, date])
  @@index([studentId])
  @@index([date])
  /// Index on status allows efficient dashboard queries like
  /// "show all LATE entries this month" without a full table scan.
  @@index([status])
  @@map("attendance_logs")
}
